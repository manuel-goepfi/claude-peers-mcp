{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "name": "claude-peers-codex-register",
            "type": "command",
            "command": "/usr/bin/env bash '/home/manzo/claude-peers-mcp/hooks/codex-register-peer-session.sh'",
            "timeout": 10,
            "statusMessage": "Registering peer session"
          },
          {
            "name": "claude-peers-codex-session-drain",
            "type": "command",
            "command": "CLAUDE_PEERS_HOOK_EVENT_NAME=SessionStart /usr/bin/env bash '/home/manzo/claude-peers-mcp/hooks/codex-drain-peer-inbox.sh'",
            "timeout": 15,
            "statusMessage": "Draining peer inbox at session start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "name": "claude-peers-codex-inbox",
            "type": "command",
            "command": "/usr/bin/env bash '/home/manzo/claude-peers-mcp/hooks/codex-drain-peer-inbox.sh'",
            "timeout": 10,
            "statusMessage": "Checking peer inbox"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "name": "claude-peers-codex-stop-drain",
            "type": "command",
            "command": "CLAUDE_PEERS_HOOK_EVENT_NAME=Stop /usr/bin/env bash '/home/manzo/claude-peers-mcp/hooks/codex-drain-peer-inbox.sh'",
            "timeout": 10,
            "statusMessage": "Checking peer inbox before stop"
          }
        ]
      }
    ]
  }
}
