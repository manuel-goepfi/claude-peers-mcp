{
  "name": "claude-peers",
  "version": "0.1.0",
  "description": "Local peer discovery and messaging for Claude Code, Codex CLI, and Gemini CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manuel-goepfi/claude-peers-mcp.git"
  },
  "engines": {
    "bun": "1.3.11"
  },
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "broker": "bun broker.ts",
    "server": "bun server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "smoke:install": "bun scripts/smoke-clean-install.ts",
    "smoke:clients": "bun scripts/smoke-real-clients.ts",
    "benchmark:peers": "bun bench/peer-fleet.ts",
    "verify": "bun run typecheck && bun test && bun run smoke:install"
  },
  "devDependencies": {
    "@types/bun": "1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
